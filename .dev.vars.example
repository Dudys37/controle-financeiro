# Copie para .dev.vars (que está no .gitignore). Apenas PLACEHOLDERS — sem valores reais.
B3_ENV=local
FIREBASE_PROJECT_ID=
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
B3_DEV_ALLOW_UNVERIFIED=false
B3_ENABLE_REAL_CALLS=false
B3_ACCESS_PACKAGE_ID=
B3_TIMEOUT_MS=10000
FIREBASE_JWKS_URL=
# Governança (Fase 16):
B3_RATE_LIMIT_ENABLED=true
B3_RATE_LIMIT_STATUS_5M=30
B3_RATE_LIMIT_GUIDE_DAILY=5
B3_RATE_LIMIT_SYNC_DAILY=3
B3_RATE_LIMIT_REVOKE_DAILY=10
B3_REPEAT_SYNC_STRATEGY=cache
B3_SYNC_CACHE_TTL_SECONDS=172800
B3_AUDIT_ENABLED=true
B3_METRICS_ENABLED=false
B3_METRICS_ADMIN_UIDS=
B3_UID_HASH_SALT=
# Segredos locais (placeholders — nunca reais):
B3_BASE_URL=
B3_CLIENT_ID=
B3_CLIENT_SECRET=
B3_CERT=
B3_KEY=
